# Ignore bundler config
/.bundle

# Ignore all logfiles and tempfiles
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep

# Ignore storage (uploaded files)
/storage/*
!/storage/.keep

# Ignore master key
/config/master.key
/config/credentials/*.key

# Ignore dotenv
.env
.env.*

# Ignore pidfiles
/tmp/pids/*
!/tmp/pids/.keep

# Ignore node modules (if any)
/node_modules

# Ignore byebug history
.byebug_history
